# polymarket-autopilot environment configuration
# Copy this file to .env and fill in any values.

# Path to the SQLite database (default: data/autopilot.db)
# AUTOPILOT_DB=data/autopilot.db

# Log level: DEBUG | INFO | WARNING | ERROR (default: WARNING)
# LOG_LEVEL=WARNING

# Optional: Polymarket API rate-limit pause (seconds)
# AUTOPILOT_RATE_LIMIT_SLEEP=1.0

# Risk Management: Stop-loss threshold as decimal (default: 0.10 for -10%)
# AUTOPILOT_STOP_LOSS_PCT=0.10

# Risk Management: Take-profit threshold as decimal (default: 0.20 for +20%)
# AUTOPILOT_TAKE_PROFIT_PCT=0.20
