# Live Trading Configuration
# WARNING: This enables REAL MONEY trading. Only use after thorough paper testing.

# Polymarket API Credentials
# Get these from https://polymarket.com/settings/api
POLYMARKET_API_KEY=your_api_key_here
POLYMARKET_API_SECRET=your_api_secret_here
POLYMARKET_WALLET_ADDRESS=0xYourWalletAddressHere

# Live Trading Safety Toggle
# Set to "true" to enable real order placement (use with extreme caution)
LIVE_TRADING_ENABLED=false

# Risk Limits (USD)
LIVE_MAX_DAILY_LOSS=20.0           # Max loss per day before auto-stop
LIVE_MAX_POSITION_SIZE=50.0        # Max USD per trade
LIVE_MAX_OPEN_POSITIONS=10         # Max concurrent positions
LIVE_MAX_DEPLOYED_CAPITAL_PCT=0.80 # Max 80% of capital deployed
LIVE_MIN_MARKET_LIQUIDITY=10000.0  # Min market liquidity to trade
LIVE_MAX_SLIPPAGE_PCT=0.02         # Max 2% slippage

# Monitoring & Alerts
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Database (optional override)
# DB_PATH=data/autopilot.db
